# Copy this file to `.env` (in this same wealth_agent/ folder) and fill in your key.
# ADK automatically loads this file when it runs the agent.

# Use the Gemini Developer API (an API key), not Vertex AI.
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Get a key from Google AI Studio: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key-here
